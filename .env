# ── Nexus Chat v2 — Environment Variables ─────────────────────────────────

# MongoDB Connection
# Local:
MONGODB_URI=mongodb+srv://fusion:flare@cluster0.wp977vh.mongodb.net/
# Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/nexus-chat

# Server Port


# Session Secret (change this to any random string)
SESSION_SECRET=nexus_super_secret_change_me_2024

# ── Optional: Firebase Storage ────────────────────────────────────────────
# If using Firebase instead of local disk storage, fill these:
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=

# ── Optional: AWS S3 ──────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=nexus-chat-media
